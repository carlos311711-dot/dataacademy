---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Ruta del Analista de Datos | Data Academy"
  description="Descubre el camino definitivo para convertirte en analista de datos. Explora las habilidades técnicas y blandas indispensables, y navega por nuestra ruta estructurada interactiva de dos etapas (Junior y Avanzado)."
>
  <!-- Hero Section -->
  <header class="detail-hero">
    <div class="container detail-container">
      <a href="/#formacion" class="btn-back"
        ><i class="fas fa-arrow-left"></i> Volver a Formación</a
      >
      <div class="detail-header text-center-mobile">
        <span class="course-tag">Preventa Exclusiva 2026</span>
        <h1>
          Ruta del <span class="highlight text-gradient"
            >Analista de Datos</span>
        </h1>
        <p class="subtitle-text">
          El mapa de ruta definitivo y dinámico para dominar los datos. Elige tu
          nivel y sigue el camino estructurado hacia el éxito.
        </p>
        <div
          class="hero-actions text-center-mobile"
          style="margin-top: 24px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;"
        >
          <a
            href="https://drive.google.com/file/d/1g5YhNb1XGaiG5lJS3wLBCthSq0AoxOcE/view?usp=sharing"
            target="_blank"
            class="btn btn-outline-brochure"
            ><i class="far fa-file-pdf"></i> Brochure Junior (PDF)</a
          >
          <a
            href="javascript:void(0)"
            onclick="alert('Estamos en proceso')"
            class="btn btn-outline-brochure"
            ><i class="far fa-file-pdf"></i> Brochure Avanzado (PDF)</a
          >
        </div>
      </div>
    </div>
  </header>

  <!-- ==================== TIMELINE TOGGLE CONTROLLER ==================== -->
  <section class="selector-section">
    <div class="container">
      <div class="selector-wrapper text-center">
        <div class="toggle-pill-container">
          <button
            class="toggle-btn active"
            id="btn-junior"
            data-target="junior"
          >
            <i class="fas fa-user-graduation"></i>
            <span>Ruta 1: Especialización en Data Analyst</span>
          </button>
          <button class="toggle-btn" id="btn-advanced" data-target="advanced">
            <i class="fas fa-user-shield"></i>
            <span>Ruta 2: Especialización en Data Analyst Avanzado</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== HORIZONTAL TIMELINE SECTION ==================== -->
  <section class="section timeline-section">
    <div class="container">
      <!-- ==================== ROUTE 1: JUNIOR ROADMAP ==================== -->
      <div id="wrapper-junior" class="roadmap-horizontal-wrapper active">
        <div class="roadmap-meta-header text-center">
          <h3>Especialización en Data Analyst</h3>
          <p>
            Compuesta por 4 cursos intensivos y un proyecto integrador de
            cierre. Diseñada para dar el salto profesional de 0 a 100.
          </p>
        </div>

        <div class="timeline-container">
          <!-- Background SVG Sine Curve for desktop -->
          <svg
            class="timeline-svg-curve"
            viewBox="0 0 1000 150"
            preserveAspectRatio="none"
          >
            <path
              d="M 50,75 C 150,15 250,135 350,75 C 450,15 550,135 650,75 C 750,15 850,135 950,75"
            ></path>
          </svg>

          <!-- Timeline Nodes -->
          <div class="timeline-horizontal-scroll">
            <div class="timeline-nodes-row">
              <!-- Background SVG Sine Curve for mobile -->
              <svg
                class="timeline-svg-curve-vertical"
                viewBox="0 0 100 600"
                preserveAspectRatio="none"
